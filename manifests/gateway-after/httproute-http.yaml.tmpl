apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: route-http-redirect
  namespace: devops
spec:
  parentRefs:
    - name: devops-gateway
      port: 80
  hostnames:
    - "${INGRESS_DOMAIN}"
  rules:
    - filters:
        - type: RequestRedirect
          requestRedirect:
            scheme: https
            statusCode: 301
